# Web Vite — landing, /signin, /dashboard, /admin (must match mobile Convex backend)
# Netlify: add the same VITE_* keys under Site settings → Environment variables (see NETLIFY.md).
# Use the same URL as EXPO_PUBLIC_CONVEX_URL in apps/mobile (see Convex dashboard → Settings → URL).
# Dev example: https://your-team.dev.convex.cloud — run `npx convex dev` from repo root to confirm.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Optional — App Store / Play Store links on the landing page (defaults exist in code)
# VITE_APP_STORE_URL=https://apps.apple.com/app/...
# VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=...

# Optional — footer social links (defaults: x.com/receiptcycle, instagram.com/receiptcycle)
# VITE_SOCIAL_X_URL=https://x.com/yourhandle
# VITE_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/yourhandle

# Whop checkout (Receipt Cycle Pro — use exact plan checkout links from Whop dashboard)
# VITE_WHOP_CHECKOUT_MONTHLY_URL=https://whop.com/receipt-cycle/checkout/plan_WJwS2TVMd7MvU
# VITE_WHOP_CHECKOUT_YEARLY_URL=https://whop.com/receipt-cycle/checkout/plan_MiQm0lyNxA881
# or: WHOP_CHECKOUT_MONTHLY_URL / WHOP_CHECKOUT_YEARLY_URL (vite.config maps these for the browser)
# VITE_WHOP_MANAGE_URL=https://whop.com/hub/

# --- Whop (web / Vite — public values only; never commit real secrets) ---
# VITE_WHOP_OAUTH_CLIENT_ID=app_kMFUEC8UntlEKY
# or: VITE_WHOP_CLIENT_ID=app_kMFUEC8UntlEKY
# or same app id as Convex: WHOP_OAUTH_CLIENT_ID / WHOP_CLIENT_ID (vite.config maps these for the browser)
# OAuth redirect must match Whop app + Convex allowlist exactly (pick one env name):
# VITE_WHOP_REDIRECT_URI=https://receiptcycle.com/api/auth/callback
# or: VITE_WHOP_OAUTH_REDIRECT_URI=https://receiptcycle.com/api/auth/callback/whop
# Routes that work: /oauth/whop, /api/auth/callback, /api/auth/callback/whop, /auth/callback

# --- Whop + session (Convex Dashboard → Environment variables, not in git) ---
# WHOP_CLIENT_ID=app_kMFUEC8UntlEKY          # alias: same as WHOP_OAUTH_CLIENT_ID (either name works)
# WHOP_OAUTH_CLIENT_ID=app_kMFUEC8UntlEKY
# WHOP_API_KEY=                             # app API key — for future server calls to Whop REST; optional today
# WHOP_COMPANY_API_KEY=                     # company API key from Whop “Company API Keys”; optional today
# WHOP_OAUTH_CLIENT_SECRET=                 # or WHOP_CLIENT_SECRET — if Whop requires confidential token exchange
# WHOP_REDIRECT_URI=https://receiptcycle.com/api/auth/callback
#   or WHOP_REDIRECT_URIS=uri1,uri2        # if set, token exchange rejects unknown redirect_uri (must match web)
# WHOP_WEBHOOK_SECRET=                      # webhook signing secret (Standard Webhooks)
# WHOP_PRO_PRODUCT_IDS=prod_CT6cyQj9lXcX6
# SESSION_SECRET=                           # not used by Receipt Cycle Convex auth today; keep for other tooling if needed
# PUBLIC_WEB_APP_URL=https://receiptcycle.com
# Webhook URL in Whop dashboard: https://<YOUR_DEPLOYMENT>.convex.site/whop-webhook
