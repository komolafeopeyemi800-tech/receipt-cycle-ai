# Convex (required for the app)
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Marketing — opened from Settings → Upgrade to premium
EXPO_PUBLIC_PRICING_URL=https://receiptcycle.app/pricing

# Whop checkout (same prices as web; set when products are live)
# EXPO_PUBLIC_WHOP_CHECKOUT_MONTHLY_URL=https://whop.com/checkout/...
# EXPO_PUBLIC_WHOP_CHECKOUT_YEARLY_URL=https://whop.com/checkout/...
# EXPO_PUBLIC_WHOP_MANAGE_URL=https://whop.com/hub/...

# Whop OAuth — same app id as Convex WHOP_OAUTH_CLIENT_ID. Default native redirect path is auth/callback → receiptcycle://auth/callback (must match Whop).
# EXPO_PUBLIC_WHOP_OAUTH_CLIENT_ID=app_kMFUEC8UntlEKY
# EXPO_PUBLIC_WHOP_OAUTH_REDIRECT_PATH=auth/callback
# Legacy path if Whop still has receiptcycle://oauth/whop only:
# EXPO_PUBLIC_WHOP_OAUTH_REDIRECT_PATH=oauth/whop

# Optional: Convex site URL if you use Convex-hosted pages
# EXPO_PUBLIC_CONVEX_SITE_URL=

# Google (mobile): same OAuth client IDs are used for Drive backup and “Sign in with Google”.
# In Google Cloud Console: enable Google Drive API, create iOS + Android OAuth clients, add redirect URIs:
#   receiptcycle://google-drive-oauth
#   receiptcycle://google-signin
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com

# Convex Dashboard → Environment (server): verify Google ID tokens from the app
# GOOGLE_IOS_CLIENT_ID=same-as-ios-client-id.apps.googleusercontent.com
# GOOGLE_ANDROID_CLIENT_ID=same-as-android-client-id.apps.googleusercontent.com

# Optional: password reset emails (Resend). Without RESEND_API_KEY, dev builds return a token in-app.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Receipt Cycle <verified@yourdomain.com>

# Do NOT put GEMINI_API_KEY / OPENAI_API_KEY / OPENROUTER_API_KEY here — set them in Convex Dashboard → Environment Variables.
# Primary scan: OPENAI_API_KEY (recommended). Gemini fallback: OPENROUTER_API_KEY (avoids Google 429) or GEMINI_API_KEY.
# Same OPENAI_API_KEY powers receipt OCR, money-leak analysis, voice→text (Whisper), voice transaction parsing, and the finance coach chat.
# Optional: OPENAI_VISION_MODEL=gpt-4o-mini, OPENROUTER_GEMINI_MODEL=google/gemini-2.0-flash-001
# See docs/CONVEX_SECRETS.md
